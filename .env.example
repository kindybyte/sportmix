# ───────────────────────────────────────────────────────────
# SportMix — переменные окружения
# Скопируйте этот файл в .env.local и заполните значения.
# НИКОГДА не коммитьте .env.local в репозиторий.
# ───────────────────────────────────────────────────────────

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service Role key — ТОЛЬКО на сервере (для записи заявок).
# Никогда не используйте с префиксом NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Telegram Bot API
# 1. Создайте бота через @BotFather → получите токен.
# 2. Узнайте свой chat_id через @userinfobot или getUpdates.
TELEGRAM_BOT_TOKEN=123456789:AAaaBBbbCCccDDddEEeeFFffGGgg
TELEGRAM_CHAT_ID=123456789

# Публичный адрес сайта (для canonical-ссылок и sitemap)
NEXT_PUBLIC_SITE_URL=https://sportmix.vercel.app

# Email-адреса администраторов через запятую (доступ в /admin).
# Если пусто — в админку пускается любой авторизованный пользователь Supabase.
# Рекомендуется указать ваш email.
ADMIN_EMAILS=admin@sportmix.kg
